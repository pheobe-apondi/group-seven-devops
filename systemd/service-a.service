[Unit]
Description=Service A
After=network.target service-b.service service-c.service
Requires=service-b.service service-c.service

[Service]
Type=simple
WorkingDirectory=/home/administrator/group-seven-devops
ExecStart=/usr/bin/python3 /home/administrator/group-seven-devops/services/service_a.py
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target